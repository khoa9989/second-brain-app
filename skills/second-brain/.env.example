# REQUIRED - each user/site must create unique values. Never reuse someone else's values.
SB_BLOBS_STORE=second-brain-store-yourname-YYYYMMDDHHMMSS
SB_BLOBS_SITE_ID=your-netlify-site-id
SB_BLOBS_TOKEN=your-netlify-personal-access-token

# REQUIRED for server-side login. Use SHA256(password).
SB_LOGIN_PASSWORD_SHA256=sha256_of_your_password
SB_AUTH_SECRET=random_32_plus_character_secret

# Optional LLM config for brain-query, if supported by your deployment
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
